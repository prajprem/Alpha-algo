import { useState, useEffect, useCallback, useRef } from "react";

/* ─── DEFAULT ASSETS ─────────────────────────────────────────── */
const DEFAULT_CRYPTO = [
  { symbol:"BTC",  name:"Bitcoin",   cgId:"bitcoin",      bnSym:"BTCUSDT", color:"#F7931A", dec:2 },
  { symbol:"ETH",  name:"Ethereum",  cgId:"ethereum",     bnSym:"ETHUSDT", color:"#627EEA", dec:2 },
